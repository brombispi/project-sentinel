#!/usr/bin/env python3

import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
sys.path.append(str(PROJECT_ROOT))

from modules.argus import collect_smart_report, detect_devices
from modules.aegis import evaluate
from modules.oracle import create_strategy
from modules.summary import format_bytes, print_summary
from modules.archive import (
    create_session,
    execute_forensic_image,
    execute_photorec_recovery,
    relocate_recovery_case,
    verify_forensic_image,
)
from modules.echo import log_info, log_operator, log_warning
from modules.session_manager import save_case, update_status
from modules.intake import collect_case_intake
from modules.janus import evaluate_destination
from modules.device_selection import (
    print_device_selection_list,
    select_source_device,
    select_destination_device,
)
from core.codex import Codex
from core.status import RecoveryStatus


print("==========================================")
print("PROJECT SENTINEL")
print("==========================================")
print()

case_name = input("Case name: ").strip()

session = create_session()
intake = collect_case_intake()

session.case_name = case_name

if session.case_name == "":
    session.case_name = session.session_id

log_info(
    session,
    "SENTINEL",
    f"Case name set: {session.case_name}"
)

log_info(
    session,
    "INTAKE",
    "Recovery case intake completed."
)

log_info(
    session,
    "SENTINEL",
    "Assessment started."
)

devices = detect_devices()
device_count = len(devices)

if device_count == 1:
    log_info(
        session,
        "ARGUS",
        f"Detected 1 storage device: {devices[0].path}"
    )
else:
    log_info(
        session,
        "ARGUS",
        f"Detected {device_count} storage devices."
    )

print(f"Recovery Case : {session.session_id}")
print(f"Case Name     : {session.case_name}")
print()

print_device_selection_list(
    "SOURCE DEVICE SELECTION",
    devices
)

source_device = select_source_device(devices)
session.source_device = source_device

assessment = evaluate(session.source_device)
session.assessment = assessment

update_status(
    session,
    RecoveryStatus.ASSESSING,
    session.source_device,
    assessment,
    intake=intake,
)

strategy = create_strategy(assessment)

log_info(
    session,
    "ORACLE",
    f"Strategy generated: {strategy.status} / {strategy.priority}"
)

log_info(
    session,
    "CODEX",
    f"Knowledge applied for: {source_device.filesystem}"
)

print(f"Device     : {source_device.path}")
print(f"Model      : {source_device.model}")
print(f"Serial     : {source_device.serial}")
print(f"Filesystem : {source_device.filesystem}")
print(f"Role       : {source_device.role}")
print()

codex = Codex()

print("CODEX")

for filesystem in source_device.filesystem.split(","):
    key = filesystem.strip().lower()
    knowledge = codex.lookup("filesystem", key)

    if knowledge:
        print(f"Filesystem : {key}")

        if "warning" in knowledge:
            print(f"Warning    : {knowledge['warning']}")

        if "risk" in knowledge:
            print(f"Risk       : {knowledge['risk']}")

        if "recommended_action" in knowledge:
            print(f"Action     : {knowledge['recommended_action']}")

        print()

print("AEGIS")
print(f"Decision   : {assessment.decision.status}")
print(f"Reason     : {assessment.decision.reason}")

print()
print("ORACLE")
print(f"Goal       : {strategy.goal}")
print(f"Priority   : {strategy.priority}")

print()
print("Strategy")

for step in strategy.steps:
    print(f"- {step}")

smart_result = None
imaging_result = None
integrity_result = None
recovery_result = None
imaging_declined = False
recovery_declined = False

if assessment.decision.status == "STOP":
    update_status(
        session,
        RecoveryStatus.ON_HOLD,
        session.source_device,
        assessment,
        intake=intake
    )

    log_warning(
        session,
        "AEGIS",
        f"Decision: STOP ({assessment.decision.reason})"
    )
else:
    log_info(
        session,
        "AEGIS",
        f"Decision: {assessment.decision.status}"
    )

    smart_output_path = (
        Path(session.recovery_path) / "evidence" / "source.smart.txt"
    )
    smart_result = collect_smart_report(
        session.source_device,
        smart_output_path,
    )

    print()
    print("SMART")
    print(f"Available  : {'YES' if smart_result['available'] else 'NO'}")
    print(f"Health     : {smart_result['health']}")
    print(f"Saved to   : {smart_result['output_path']}")

    if smart_result["warning"]:
        print(f"Warning    : {smart_result['warning']}")

    if smart_result["available"]:
        log_info(
            session,
            "ARGUS",
            f"SMART report collected: health {smart_result['health']}",
        )
    else:
        log_warning(
            session,
            "ARGUS",
            smart_result["warning"] or "SMART report unavailable.",
        )

    destination_candidates = [
        device for device in devices
        if device.path != session.source_device.path
    ]

    print_device_selection_list(
        "DESTINATION DEVICE SELECTION",
        destination_candidates
    )

    session.destination_device = select_destination_device(
        destination_candidates
    )
    destination_assessment = evaluate_destination(session.destination_device)

    print()
    print("JANUS")
    print(f"Approved  : {'YES' if destination_assessment.approved else 'NO'}")
    print(f"Reason    : {destination_assessment.reason}")
    print(f"Risk      : {destination_assessment.risk}")

    case_relocated = False

    if destination_assessment.approved:
        relocate_result = relocate_recovery_case(
            session,
            session.destination_device.mount_point,
        )

        print()
        print("ARCHIVE")
        print(f"Status     : {relocate_result['status']}")
        print(f"Result     : {relocate_result['message']}")

        case_relocated = relocate_result["success"]

    if destination_assessment.approved and case_relocated:
        update_status(
            session,
            RecoveryStatus.READY_FOR_IMAGING,
            session.source_device,
            assessment,
            intake=intake,
        )
    else:
        save_case(session, intake=intake)

    if destination_assessment.approved and case_relocated:
        print("\nRECOVERY")
        print("Operation  : Create forensic image")
        print(f"Source     : {session.source_device.path}")
        print(f"Output     : {session.recovery_path}/images/source.img")

        confirm = input("Proceed with forensic imaging? [y/N]: ").strip().lower()

        if confirm == "y":
            update_status(
                session,
                RecoveryStatus.IMAGING,
                session.source_device,
                assessment,
                intake=intake,
            )

            imaging_result = execute_forensic_image(session)

            print()
            print("ARCHIVE")
            print(f"Status     : {imaging_result['status']}")
            print(f"Result     : {imaging_result['message']}")

            if imaging_result["artifacts"]:
                print("Artifacts  :")
                for artifact in imaging_result["artifacts"]:
                    print(f"- {artifact}")

            if imaging_result["success"]:
                integrity_result = verify_forensic_image(session)

                print()
                print("INTEGRITY")
                print(f"Image      : {integrity_result['image_filename']}")
                print(f"Algorithm  : {integrity_result['algorithm']}")

                if integrity_result["success"]:
                    print("Result     : Hash recorded")
                    print(f"SHA-256    : {integrity_result['digest']}")
                    print(f"Saved to   : {integrity_result['evidence_path']}")
                else:
                    print("Result     : Failed")
                    print(f"Error      : {integrity_result['message']}")

                update_status(
                    session,
                    RecoveryStatus.READY_FOR_RECOVERY,
                    session.source_device,
                    assessment,
                    intake=intake,
                )

                if integrity_result["success"]:
                    print("\nRECOVERY")
                    print("Operation  : Recover files with PhotoRec")
                    print(
                        f"Source image     : "
                        f"{session.recovery_path}/images/source.img"
                    )
                    print(
                        f"Recovery output  : "
                        f"{session.recovery_path}/recovered/"
                    )

                    recovery_confirm = input(
                        "Proceed with PhotoRec recovery? [y/N]: "
                    ).strip().lower()

                if integrity_result["success"] and recovery_confirm == "y":
                    update_status(
                        session,
                        RecoveryStatus.RECOVERING,
                        session.source_device,
                        assessment,
                        intake=intake,
                    )

                    recovery_result = execute_photorec_recovery(session)

                    update_status(
                        session,
                        RecoveryStatus.READY_FOR_RECOVERY,
                        session.source_device,
                        assessment,
                        intake=intake,
                    )

                    photorec_session = (
                        "Ended normally"
                        if recovery_result["success"]
                        else "Failed"
                    )

                    print()
                    print("RECOVERY RESULT")
                    print(f"PhotoRec session      : {photorec_session}")
                    print(
                        "Recovered directories : "
                        f"{recovery_result['recovered_directory_count']}"
                    )
                    print(
                        "Recovered files       : "
                        f"{recovery_result['recovered_file_count']}"
                    )
                    print(
                        "Recovered size        : "
                        f"{format_bytes(recovery_result['recovered_total_bytes'])}"
                    )
                    print(f"Case status           : {session.status}")
                elif integrity_result["success"]:
                    recovery_declined = True
                    log_operator(
                        session,
                        "SENTINEL",
                        "PhotoRec recovery declined.",
                    )
            else:
                update_status(
                    session,
                    RecoveryStatus.READY_FOR_IMAGING,
                    session.source_device,
                    assessment,
                    intake=intake,
                )
        else:
            imaging_declined = True

print()
print_summary(
    assessment,
    strategy,
    session,
    smart_result=smart_result,
    imaging_result=imaging_result,
    integrity_result=integrity_result,
    recovery_result=recovery_result,
    imaging_declined=imaging_declined,
    recovery_declined=recovery_declined,
)

print("-" * 40)

log_info(
    session,
    "SENTINEL",
    "Assessment completed."
)