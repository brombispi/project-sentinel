sys.path.append(str(PROJECT_ROOT))

from modules.argus import (
    collect_smart_report,
    detect_devices,
    observe_mounted_descendants,
)
from modules.aegis import evaluate
from modules.oracle import create_strategy, recommend_recovery_method
from modules.summary import format_bytes, print_summary
from modules.archive import (
    build_exclude_mount_targets,
    classify_acquisition_state,
    create_session,
    execute_forensic_image,
    execute_photorec_recovery,
    relocate_recovery_case,
    unmount_source_descendants,
    validate_source_identity_for_resume,
    verify_forensic_image,
)
