_warned_audit_failures = set()


def _handle_audit_log_failure(result):
    """
    Presentation-boundary sink for ECHO audit-log write failures.

    Warns the operator once per case that an audit entry could not be
    recorded, without claiming the primary operation succeeded or failed.
    """

    recovery_path = result.get("recovery_path", "")

    if recovery_path in _warned_audit_failures:
        return

    _warned_audit_failures.add(recovery_path)

    print()
    print(tr("error.audit_log_failed"))


def _confirmed_yes(response):
    return response.strip().lower() in ("y", "j")


def _language_display_name(language_code):
    return {
        "en": "English",
        "de": "Deutsch",
    }.get(language_code, language_code)


def _log_case_load_failure(session, load_result):
    code = load_result.get("code")
    message = load_result.get("message", "")

    if code == CODE_AMBIGUOUS_SOURCE:
        log_warning(
            session,
            "SENTINEL",
            "Ambiguous source device match.",
        )
        return

    if code == CODE_AMBIGUOUS_DESTINATION:
        log_warning(
            session,
            "SENTINEL",
            "Ambiguous destination device match.",
        )
        return

    if code == CODE_SOURCE_NOT_CONNECTED:
        log_error(
            session,
            "SENTINEL",
            "Source device missing.",
        )
        return

    if code in (
        CODE_DESTINATION_NOT_CONNECTED,
        CODE_DESTINATION_NOT_MOUNTED,
    ):
        log_error(
            session,
            "SENTINEL",
            "Destination device missing.",
        )
        return

    log_error(
        session,
        "SENTINEL",
        f"Case load failed: {message}",
    )


def _prompt_language_selection():
    print()
    print("=" * 42)
    print(tr("language.prompt.title"))
    print("=" * 42)
    print()
    print(tr("language.option.en"))
    print(tr("language.option.de"))
    print(tr("language.option.cancel"))
    print()

    while True:
        choice = input(tr("language.prompt.select")).strip().lower()

        if choice == "1":
            set_language("en")
            print(tr("language.saved"))
            return

        if choice == "2":
            set_language("de")
            print(tr("language.saved"))
            return

        if choice in ("c", "cancel"):
            return

        print(tr("validation.invalid_selection"))


def _print_mounted_descendants(mounted_descendants):
    print(tr("mount.descendants.title"))
    for item in mounted_descendants:
        options = item.get("options") or "unknown"
        filesystem = item.get("filesystem") or "unknown"
        node_type = item.get("type") or "unknown"
        print(
            tr(
                "mount.descendants.line",
                device_path=item["device_path"],
                mount_target=item["mount_target"],
                node_type=node_type,
                filesystem=filesystem,
                options=options,
            )
        )


def _run_mount_safety_gate(session, devices):
    exclude_mount_targets = build_exclude_mount_targets(
        devices,
        session.destination_device,
    )
    mounted_descendants = observe_mounted_descendants(
        session.source_device.path,
        exclude_mount_targets=exclude_mount_targets,
        session=session,
    )

    if not mounted_descendants:
        return True, exclude_mount_targets

    print()
    _print_mounted_descendants(mounted_descendants)
    print()
    print(tr("mount.warning.os_modify"))

    unmount_confirm = input(tr("mount.prompt.unmount")).strip().lower()

    if not _confirmed_yes(unmount_confirm):
        log_operator(
            session,
            "SENTINEL",
            "Unmount of mounted descendants declined.",
        )
        print()
        print(tr("mount.refused.title"))
        print(tr("mount.refused.descendants_remain"))
        return False, exclude_mount_targets

    log_operator(
        session,
        "SENTINEL",
        "Unmount of mounted descendants approved.",
    )

    unmount_result = unmount_source_descendants(
        session,
        mounted_descendants,
    )

    mounted_descendants = observe_mounted_descendants(
        session.source_device.path,
        exclude_mount_targets=exclude_mount_targets,
        session=session,
    )
    log_info(
        session,
        "SENTINEL",
        "Post-unmount mounted-descendant verification completed.",
    )

    if mounted_descendants:
        print()
        print(tr("mount.refused.title"))
        print(operator_message(unmount_result, "archive"))
        _print_mounted_descendants(mounted_descendants)
        return False, exclude_mount_targets

    return True, exclude_mount_targets


def _identity_field(value):
    if value is None or value == "":
        return tr("identity.missing")
    return value


def _operator_oracle_goal(goal):
    displayed = display_oracle_goal(goal)
    if displayed == goal:
        translated = tr(goal)
        if not translated.startswith("["):
            return translated
    return displayed


def _operator_oracle_step(step, recommendation=None):
    displayed = display_oracle_step(step, recommendation=recommendation)
    if displayed == step:
        translated = tr(step)
        if not translated.startswith("["):
            return translated
    return displayed


def _print_identity_comparison(identity_result):
    recorded = identity_result["recorded"] or {}
    current = identity_result["current"]

    print(tr("identity.title"))
    print(
        tr("identity.label.recorded_serial"),
        _identity_field(recorded.get("serial")),
    )
    print(
        tr("identity.label.current_serial"),
        _identity_field(current.get("serial")),
    )
    print(
        tr("identity.label.recorded_model"),
        _identity_field(recorded.get("model")),
    )
    print(
        tr("identity.label.current_model"),
        _identity_field(current.get("model")),
    )
    print(
        tr("identity.label.recorded_size_bytes"),
        _identity_field(recorded.get("size_bytes")),
    )
    print(
        tr("identity.label.current_size_bytes"),
        _identity_field(current.get("size_bytes")),
    )
    print(
        tr("identity.label.recorded_path"),
        _identity_field(recorded.get("path")),
    )
    print(
        tr("identity.label.current_path"),
        _identity_field(current.get("path")),
    )

    for warning in identity_result.get("warnings", []):
        if isinstance(warning, dict):
            warning_text = operator_message(warning, "archive")
        else:
            warning_text = warning
        print(tr("identity.label.warning"), warning_text)


def _run_recovery_method_selection(session, assessment, intake):
    recommendation = recommend_recovery_method()

    log_info(
        session,
        "ORACLE",
        "Recovery recommendation: "
        f"{recommendation['recommended_operation']} / "
        f"{recommendation['confidence']}",
    )

    print()
    print("=" * 42)
    print(tr("recovery.method.title"))
    print("=" * 42)
    print()
    recommended_operation = (
        "PhotoRec"
        if recommendation["recommended_operation"] == "photorec"
        else recommendation["recommended_operation"]
    )
    print(tr("recovery.label.recommended"), recommended_operation)
    print(tr("recovery.label.confidence"), recommendation["confidence"])
    print(tr("recovery.label.reason"), tr(recommendation["reason"]))
    print()
    print(tr("recovery.label.available_operations"))
    print()
    print(tr("recovery.option.photorec"))
    print(tr("recovery.option.desc"))
    print()
    print(tr("recovery.option.cancel"))
    print()
    print(tr("recovery.note.testdisk"))
    print()

    recovery_method_choice = None
    while recovery_method_choice is None:
        choice = input(tr("recovery.prompt.select")).strip()
        if choice == "1":
            recovery_method_choice = "photorec"
        elif choice == "2":
            recovery_method_choice = "cancel"
        else:
            print(tr("validation.invalid_selection"))

    if recovery_method_choice == "photorec":
        log_operator(
            session,
            "SENTINEL",
            "Recovery method selected: PhotoRec.",
        )

        filesystems = [
            filesystem.strip().lower()
            for filesystem in session.source_device.filesystem.split(",")
            if filesystem.strip()
        ]
        ext_filesystems = {"ext2", "ext3", "ext4"}
        detected_ext = [
            filesystem
            for filesystem in filesystems
            if filesystem in ext_filesystems
        ]

        print()
        print("=" * 42)
        print(tr("photorec.guidance.title"))
        print("=" * 42)
        print()

        if detected_ext:
            print(
                tr(
                    "photorec.filesystem.ext",
                    filesystem=detected_ext[0],
                )
            )
        else:
            print(tr("photorec.filesystem.other"))

        print()
        print(tr("photorec.scan.title"))
        print()
        print(tr("photorec.scan.free"))
        print()
        print(tr("photorec.scan.whole"))
        print()
        print(tr("photorec.select_mode"))
        print()

        print()
        print(tr("photorec.recovery.title"))
        print(tr("photorec.recovery.operation"))
        print(
            tr(
                "photorec.recovery.source_image",
                image_path=f"{session.recovery_path}/images/source.img",
            )
        )
        print(
            tr(
                "photorec.recovery.output",
                output_path=f"{session.recovery_path}/recovered/",
            )
        )

        recovery_confirm = input(tr("photorec.prompt.proceed")).strip().lower()

        if _confirmed_yes(recovery_confirm):
            update_status(
                session,
                RecoveryStatus.RECOVERING,
                session.source_device,
                assessment,
                intake=intake,
            )

            recovery_result = execute_photorec_recovery(session)

            update_status(
                session,
                RecoveryStatus.READY_FOR_RECOVERY,
                session.source_device,
                assessment,
                intake=intake,
            )

            photorec_session = (
                tr("recovery.result.ended_normally")
                if recovery_result["success"]
                else tr("recovery.result.failed")
            )

            print()
            print(tr("recovery.result.title"))
            print(tr("recovery.result.photorec_session"), photorec_session)
            print(
                tr("recovery.result.recovered_directories"),
                recovery_result["recovered_directory_count"],
            )
            print(
                tr("recovery.result.recovered_files"),
                recovery_result["recovered_file_count"],
            )
            print(
                tr("recovery.result.recovered_size"),
                format_bytes(recovery_result["recovered_total_bytes"]),
            )
            print(tr("recovery.result.case_status"), session.status)
            return recovery_result, False, False

        log_operator(
            session,
            "SENTINEL",
            "PhotoRec recovery declined.",
        )
        return None, True, False

    log_operator(
        session,
        "SENTINEL",
        "Recovery method selection cancelled.",
    )
    return None, False, True


def _print_assessment_context(source_device, assessment, strategy):
    print(tr("assessment.label.device"), source_device.path)
    print(tr("assessment.label.model"), source_device.model)
    print(tr("assessment.label.serial"), source_device.serial)
    print(tr("assessment.label.filesystem"), source_device.filesystem)
    print(tr("assessment.label.role"), source_device.role)
    print()

    codex = Codex()

    print(tr("assessment.section.codex"))

    for filesystem in source_device.filesystem.split(","):
        key = filesystem.strip().lower()
        knowledge = codex.lookup("filesystem", key)

        if knowledge:
            print(tr("codex.label.filesystem"), key)

            if "warning" in knowledge:
                print(tr("codex.label.warning"), tr(knowledge["warning"]))

            if "risk" in knowledge:
                print(tr("codex.label.risk"), tr(knowledge["risk"]))

            if "recommended_action" in knowledge:
                print(
                    tr("codex.label.action"),
                    tr(knowledge["recommended_action"]),
                )

            print()

    print(tr("assessment.section.aegis"))
    print(tr("aegis.label.decision"), assessment.decision.status)
    print(
        tr("aegis.label.reason"),
        display_aegis_reason(assessment.decision.reason),
    )

    print()
    print(tr("assessment.section.oracle"))
    print(tr("oracle.label.goal"), _operator_oracle_goal(strategy.goal))
    print(tr("oracle.label.priority"), strategy.priority)

    print()
    print(tr("oracle.label.strategy"))

    for step in strategy.steps:
        print(f"- {_operator_oracle_step(step)}")


def _run_integrity_and_completion(session, assessment, intake):
    integrity_result = verify_forensic_image(session)

    print()
    print(tr("integrity.title"))
    print(tr("integrity.label.image"), integrity_result["image_filename"])
    print(tr("integrity.label.algorithm"), integrity_result["algorithm"])

    if integrity_result["success"]:
        print(tr("integrity.label.result"), tr("integrity.result.recorded"))
        print(tr("integrity.label.sha256"), integrity_result["digest"])
        print(tr("integrity.label.saved_to"), integrity_result["evidence_path"])

        update_status(
            session,
            RecoveryStatus.READY_FOR_RECOVERY,
            session.source_device,
            assessment,
            intake=intake,
        )

        (
            recovery_result,
            recovery_declined,
            recovery_selection_cancelled,
        ) = _run_recovery_method_selection(
            session,
            assessment,
            intake,
        )

        return (
            integrity_result,
            recovery_result,
            recovery_declined,
            recovery_selection_cancelled,
        )

    print(tr("integrity.label.result"), tr("integrity.result.failed"))
    print(
        tr("integrity.label.error"),
        operator_message(integrity_result, "archive"),
    )
    update_status(
        session,
        RecoveryStatus.READY_FOR_IMAGING,
        session.source_device,
        assessment,
        intake=intake,
    )

    return (integrity_result, None, False, False)


def _run_acquisition_workflow(session, devices, assessment, intake):
    imaging_result = None
    integrity_result = None
    recovery_result = None
    imaging_declined = False
    recovery_declined = False
    recovery_selection_cancelled = False

    acquisition_state = classify_acquisition_state(session.recovery_path)
    log_info(
        session,
        "SENTINEL",
        f"Acquisition state classified: {acquisition_state['state']}",
    )

    if acquisition_state["state"] == "completed_canonical":
        print()
        print(tr("imaging.refused.title"))
        print(operator_message(acquisition_state, "archive"))
        print(tr("imaging.refused.canonical_preserved"))
        log_info(
            session,
            "SENTINEL",
            "Resume refused: canonical acquisition complete.",
        )
        update_status(
            session,
            RecoveryStatus.READY_FOR_IMAGING,
            session.source_device,
            assessment,
            intake=intake,
        )

    elif acquisition_state["state"] == "inconsistent_artifacts":
        print()
        print(tr("imaging.refused.title"))
        print(operator_message(acquisition_state, "archive"))
        print(tr("imaging.refused.manual_investigation"))
        log_error(
            session,
            "SENTINEL",
            "Inconsistent acquisition artifacts detected.",
        )
        update_status(
            session,
            RecoveryStatus.READY_FOR_IMAGING,
            session.source_device,
            assessment,
            intake=intake,
        )

    elif acquisition_state["state"] == "invalid_map":
        print()
        print(tr("imaging.refused.title"))
        print(operator_message(acquisition_state, "archive"))
        print(tr("imaging.refused.no_overwrite"))
        log_error(
            session,
            "SENTINEL",
            "Resume refused: unreadable ddrescue map.",
        )
        update_status(
            session,
            RecoveryStatus.READY_FOR_IMAGING,
            session.source_device,
            assessment,
            intake=intake,
        )

    elif acquisition_state["state"] == (
        "imaging_complete_fingerprint_missing"
    ):
        print()
        print(tr("imaging.fingerprint.title"))
        print(tr("imaging.fingerprint.missing"))
        print(tr("imaging.fingerprint.no_rerun"))
        log_info(
            session,
            "SENTINEL",
            "Fingerprint retry offered.",
        )

        fingerprint_confirm = input(
            tr("imaging.prompt.fingerprint")
        ).strip().lower()

        if _confirmed_yes(fingerprint_confirm):
            log_operator(
                session,
                "SENTINEL",
                "Fingerprint retry approved.",
            )
            (
                integrity_result,
                recovery_result,
                recovery_declined,
                recovery_selection_cancelled,
            ) = _run_integrity_and_completion(session, assessment, intake)
        else:
            imaging_declined = True
            log_operator(
                session,
                "SENTINEL",
                "Fingerprint retry declined.",
            )
            update_status(
                session,
                RecoveryStatus.READY_FOR_IMAGING,
                session.source_device,
                assessment,
                intake=intake,
            )

    elif acquisition_state["state"] in (
        "no_acquisition",
        "incomplete_ddrescue",
    ):
        if acquisition_state["state"] == "incomplete_ddrescue":
            identity_result = validate_source_identity_for_resume(session)

            print()
            print(tr("imaging.resume.title"))
            print(
                tr("imaging.label.image"),
                f"{session.recovery_path}/images/source.img",
            )
            print(
                tr("imaging.label.map"),
                f"{session.recovery_path}/images/source.map",
            )
            print()
            _print_identity_comparison(identity_result)
            print()

            if not identity_result["valid"]:
                print(tr("imaging.refused.title"))
                print(operator_message(identity_result, "archive"))
                log_error(
                    session,
                    "SENTINEL",
                    "Resume refused: identity mismatch.",
                )
                update_status(
                    session,
                    RecoveryStatus.READY_FOR_IMAGING,
                    session.source_device,
                    assessment,
                    intake=intake,
                )
            else:
                mount_gate_passed, exclude_mount_targets = (
                    _run_mount_safety_gate(session, devices)
                )

                if not mount_gate_passed:
                    update_status(
                        session,
                        RecoveryStatus.READY_FOR_IMAGING,
                        session.source_device,
                        assessment,
                        intake=intake,
                    )
                else:
                    print(tr("imaging.ddrescue.continue"))

                    confirm = input(tr("imaging.prompt.resume")).strip().lower()

                    if _confirmed_yes(confirm):
                        update_status(
                            session,
                            RecoveryStatus.IMAGING,
                            session.source_device,
                            assessment,
                            intake=intake,
                        )

                        imaging_result = execute_forensic_image(
                            session,
                            resume=True,
                            exclude_mount_targets=exclude_mount_targets,
                        )

                        print()
                        print(tr("archive.title"))
                        print(tr("archive.label.status"), imaging_result["status"])
                        print(
                            tr("archive.label.result"),
                            operator_message(imaging_result, "archive"),
                        )

                        if imaging_result["artifacts"]:
                            print(tr("archive.label.artifacts"))
                            for artifact in imaging_result["artifacts"]:
                                print(f"- {artifact}")

                        if imaging_result["success"]:
                            (
                                integrity_result,
                                recovery_result,
                                recovery_declined,
                                recovery_selection_cancelled,
                            ) = _run_integrity_and_completion(
                                session,
                                assessment,
                                intake,
                            )
                        else:
                            update_status(
                                session,
                                RecoveryStatus.READY_FOR_IMAGING,
                                session.source_device,
                                assessment,
                                intake=intake,
                            )
                    else:
                        imaging_declined = True
                        log_operator(
                            session,
                            "SENTINEL",
                            "Forensic imaging resume declined.",
                        )
                        update_status(
                            session,
                            RecoveryStatus.READY_FOR_IMAGING,
                            session.source_device,
                            assessment,
                            intake=intake,
                        )
        else:
            mount_gate_passed, exclude_mount_targets = (
                _run_mount_safety_gate(session, devices)
            )

            if not mount_gate_passed:
                update_status(
                    session,
                    RecoveryStatus.READY_FOR_IMAGING,
                    session.source_device,
                    assessment,
                    intake=intake,
                )
            else:
                print()
                print(tr("imaging.new.title"))
                print(
                    tr("imaging.label.operation"),
                    tr("oracle.step.create_forensic_image").rstrip("."),
                )
                print(tr("imaging.label.source"), session.source_device.path)
                print(
                    tr("imaging.label.output"),
                    f"{session.recovery_path}/images/source.img",
                )
                print(
                    tr("imaging.label.map"),
                    f"{session.recovery_path}/images/source.map",
                )

                confirm = input(tr("imaging.prompt.new")).strip().lower()

                if _confirmed_yes(confirm):
                    update_status(
                        session,
                        RecoveryStatus.IMAGING,
                        session.source_device,
                        assessment,
                        intake=intake,
                    )

                    imaging_result = execute_forensic_image(
                        session,
                        resume=False,
                        exclude_mount_targets=exclude_mount_targets,
                    )

                    print()
                    print(tr("archive.title"))
                    print(tr("archive.label.status"), imaging_result["status"])
                    print(
                        tr("archive.label.result"),
                        operator_message(imaging_result, "archive"),
                    )

                    if imaging_result["artifacts"]:
                        print(tr("archive.label.artifacts"))
                        for artifact in imaging_result["artifacts"]:
                            print(f"- {artifact}")

                    if imaging_result["success"]:
                        (
                            integrity_result,
                            recovery_result,
                            recovery_declined,
                            recovery_selection_cancelled,
                        ) = _run_integrity_and_completion(
                            session,
                            assessment,
                            intake,
                        )
                    else:
                        update_status(
                            session,
                            RecoveryStatus.READY_FOR_IMAGING,
                            session.source_device,
                            assessment,
                            intake=intake,
                        )
                else:
                    imaging_declined = True
                    log_operator(
                        session,
                        "SENTINEL",
                        "New forensic imaging declined.",
                    )
                    update_status(
                        session,
                        RecoveryStatus.READY_FOR_IMAGING,
                        session.source_device,
                        assessment,
                        intake=intake,
                    )

    return {
        "imaging_result": imaging_result,
        "integrity_result": integrity_result,
        "recovery_result": recovery_result,
        "imaging_declined": imaging_declined,
        "recovery_declined": recovery_declined,
        "recovery_selection_cancelled": recovery_selection_cancelled,
    }


def _run_assessment_pipeline(session, intake, devices):
    smart_result = None
    workflow_results = {
        "imaging_result": None,
        "integrity_result": None,
        "recovery_result": None,
        "imaging_declined": False,
        "recovery_declined": False,
        "recovery_selection_cancelled": False,
    }

    if session.source_device is None:
        print_device_selection_list(
            tr("device.source.title"),
            devices,
        )
        source_device = select_source_device(devices)
        session.source_device = source_device
        assessment = evaluate(session.source_device)
        session.assessment = assessment

        update_status(
            session,
            RecoveryStatus.ASSESSING,
            session.source_device,
            assessment,
            intake=intake,
        )
    else:
        assessment = session.assessment
        source_device = session.source_device

    strategy = create_strategy(assessment)

    log_info(
        session,
        "ORACLE",
        f"Strategy generated: {strategy.status} / {strategy.priority}",
    )

    log_info(
        session,
        "CODEX",
        f"Knowledge applied for: {source_device.filesystem}",
    )

    _print_assessment_context(source_device, assessment, strategy)

    if assessment.decision.status == "STOP":
        update_status(
            session,
            RecoveryStatus.ON_HOLD,
            session.source_device,
            assessment,
            intake=intake,
        )

        log_warning(
            session,
            "AEGIS",
            f"Decision: STOP ({assessment.decision.reason})",
        )
        return strategy, smart_result, workflow_results

    log_info(
        session,
        "AEGIS",
        f"Decision: {assessment.decision.status}",
    )

    smart_output_path = (
        Path(session.recovery_path) / "evidence" / "source.smart.txt"
    )
    smart_result = collect_smart_report(
        session.source_device,
        smart_output_path,
    )

    print()
    print(tr("assessment.section.smart"))
    print(
        tr("smart.label.available"),
        tr("smart.available_yes")
        if smart_result["available"]
        else tr("smart.available_no"),
    )
    print(tr("smart.label.health"), smart_result["health"])
    print(tr("smart.label.saved_to"), smart_result["output_path"])

    if smart_result["warning"]:
        print(
            tr("smart.label.warning"),
            display_smart_warning(smart_result["warning"]),
        )

    if smart_result["available"]:
        log_info(
            session,
            "ARGUS",
            f"SMART report collected: health {smart_result['health']}",
        )
    else:
        log_warning(
            session,
            "ARGUS",
            smart_result["warning"] or "SMART report unavailable.",
        )

    if session.destination_device is None:
        destination_candidates = [
            device for device in devices
            if device.path != session.source_device.path
        ]

        print_device_selection_list(
            tr("device.destination.title"),
            destination_candidates,
        )

        session.destination_device = select_destination_device(
            destination_candidates
        )

    destination_assessment = evaluate_destination(session.destination_device)

    print()
    print(tr("assessment.section.janus"))
    print(
        tr("janus.label.approved"),
        tr("janus.approved_yes")
        if destination_assessment.approved
        else tr("janus.approved_no"),
    )
    print(
        tr("janus.label.reason"),
        display_janus_reason(
            destination_assessment,
            session.destination_device.mount_point
            if session.destination_device
            else None,
        ),
    )
    print(tr("janus.label.risk"), destination_assessment.risk)

    case_relocated = False
    recovery_path = Path(session.recovery_path).resolve()
    local_runtime_case = (
        recovery_path.parent == get_runtime_recoveries_root().resolve()
    )

    if destination_assessment.approved and local_runtime_case:
        relocate_result = relocate_recovery_case(
            session,
            session.destination_device.mount_point,
        )

        print()
        print(tr("archive.title"))
        print(tr("archive.label.status"), relocate_result["status"])
        print(
            tr("archive.label.result"),
            operator_message(relocate_result, "archive"),
        )

        case_relocated = relocate_result["success"]
    elif destination_assessment.approved:
        case_relocated = True

    if destination_assessment.approved and case_relocated:
        update_status(
            session,
            RecoveryStatus.READY_FOR_IMAGING,
            session.source_device,
            assessment,
            intake=intake,
        )
        workflow_results = _run_acquisition_workflow(
            session,
            devices,
            assessment,
            intake,
        )
    else:
        save_case(session, intake=intake)

    return strategy, smart_result, workflow_results


def _run_delivery_workflow(session, assessment, intake, *, recovery_result=None):
    if recovery_result is None or not recovery_result["success"]:
        return

    report_confirm = input(tr("report.prompt.generate")).strip().lower()

    if not _confirmed_yes(report_confirm):
        return

    try:
        report_path = Hermes(session).save_technician_report()
    except FileExistsError as error:
        print()
        print(error)
        return

    print()
    print(tr("report.label.saved_path", path=report_path))
    log_info(
        session,
        "HERMES",
        f"Technician report saved: {report_path}",
    )


def _parse_recovery_outcome(choice):
    return {
        "1": RecoveryOutcome.SUCCESSFUL,
        "2": RecoveryOutcome.PARTIAL,
        "3": RecoveryOutcome.UNSUCCESSFUL,
    }.get(choice.strip())


def _prompt_recovery_outcome():
    print()
    print(tr("delivery.outcome.title"))
    print(tr("delivery.outcome.option.successful"))
    print(tr("delivery.outcome.option.partial"))
    print(tr("delivery.outcome.option.unsuccessful"))
    print()

    while True:
        choice = input(tr("delivery.prompt.outcome"))
        outcome = _parse_recovery_outcome(choice)

        if outcome is not None:
            return outcome

        print(tr("validation.invalid_selection"))


def _offer_finalize_recovery(session, assessment, intake, recovery_result):
    if session.status != RecoveryStatus.READY_FOR_RECOVERY:
        return

    if session.source_device is None or assessment is None:
        return

    finalize_confirm = input(tr("delivery.prompt.finalize")).strip().lower()

    if not _confirmed_yes(finalize_confirm):
        return

    log_operator(
        session,
        "SENTINEL",
        "Recovery finalization approved.",
    )

    if session.recovery_outcome is None:
        outcome = _prompt_recovery_outcome()
        session.recovery_outcome = outcome.value
        log_operator(
            session,
            "SENTINEL",
            f"Recovery outcome recorded: {outcome.value}",
        )

    update_status(
        session,
        RecoveryStatus.COMPLETED,
        session.source_device,
        assessment,
        intake=intake,
    )

    print()
    print(tr("delivery.label.finalized"))
    _run_delivery_workflow(
        session,
        assessment,
        intake,
        recovery_result=recovery_result,
    )


def _finish_session(
    session,
    assessment,
    strategy,
    smart_result,
    workflow_results,
    *,
    intake=None,
):
    print()
    print_summary(
        assessment,
        strategy,
        session,
        smart_result=smart_result,
        imaging_result=workflow_results["imaging_result"],
        integrity_result=workflow_results["integrity_result"],
        recovery_result=workflow_results["recovery_result"],
        imaging_declined=workflow_results["imaging_declined"],
        recovery_declined=workflow_results["recovery_declined"],
        recovery_selection_cancelled=workflow_results[
            "recovery_selection_cancelled"
        ],
    )

    _offer_finalize_recovery(
        session,
        assessment,
        intake,
        workflow_results["recovery_result"],
    )

    print("-" * 40)

    log_info(
        session,
        "SENTINEL",
        "Assessment completed.",
    )


def _resolve_assessment(session, assessment):
    if assessment is not None:
        return assessment

    return session.assessment


def _require_assessment(session, assessment, workflow_name):
    resolved = _resolve_assessment(session, assessment)

    if resolved is not None:
        return resolved

    log_error(
        session,
        "SENTINEL",
        f"{workflow_name} requires a persisted assessment.",
    )
    print()
    print(
        tr(
            "error.assessment_missing",
            workflow_name=workflow_name.lower(),
        )
    )
    return None


def route_case(
    session,
    intake,
    assessment,
    devices,
    warnings,
    *,
    archive_reopened=False,
):
    for warning in warnings:
        log_warning(session, "SENTINEL", warning)

    log_info(
        session,
        "SENTINEL",
        f"Case opened: {session.session_id}",
    )

    if session.source_device:
        log_info(
            session,
            "SENTINEL",
            f"Source device re-identified: {session.source_device.path}",
        )

    if session.destination_device:
        log_info(
            session,
            "SENTINEL",
            f"Destination device re-identified: "
            f"{session.destination_device.path}",
        )

    log_info(
        session,
        "SENTINEL",
        f"Routing case by status={session.status}",
    )

    smart_result = None
    workflow_results = {
        "imaging_result": None,
        "integrity_result": None,
        "recovery_result": None,
        "imaging_declined": False,
        "recovery_declined": False,
        "recovery_selection_cancelled": False,
    }
    strategy = None

    status = session.status

    if status == RecoveryStatus.COMPLETED:
        _run_delivery_workflow(
            session,
            assessment,
            intake,
            recovery_result=None,
        )

        if not archive_reopened:
            print()
            print(tr("route.label.case_status"), status)
            print(tr("route.status.finalized"))
            reopen_confirm = input(tr("route.prompt.reopen")).strip().lower()

            if not _confirmed_yes(reopen_confirm):
                log_operator(
                    session,
                    "SENTINEL",
                    "Case reopen declined.",
                )
                return

            log_operator(
                session,
                "SENTINEL",
                "Case reopen approved.",
            )

        status = resolve_resume_status(session)
        assessment = _require_assessment(
            session,
            assessment,
            "Case reopen",
        )
        if assessment is None:
            return

        if session.source_device is None:
            log_error(
                session,
                "SENTINEL",
                "Case reopen refused: source device is not connected.",
            )
            print()
            print(tr("error.source_missing"))
            return

        update_status(
            session,
            status,
            session.source_device,
            assessment,
            intake=intake,
        )
        log_info(
            session,
            "SENTINEL",
            f"State routing decision: reopened to {status}",
        )

    elif status == RecoveryStatus.CANCELLED:
        if not archive_reopened:
            print()
            print(tr("route.label.case_status"), status)
            print(tr("route.status.finalized"))
            reopen_confirm = input(tr("route.prompt.reopen")).strip().lower()

            if not _confirmed_yes(reopen_confirm):
                log_operator(
                    session,
                    "SENTINEL",
                    "Case reopen declined.",
                )
                return

            log_operator(
                session,
                "SENTINEL",
                "Case reopen approved.",
            )

        status = resolve_resume_status(session)
        assessment = _require_assessment(
            session,
            assessment,
            "Case reopen",
        )
        if assessment is None:
            return

        if session.source_device is None:
            log_error(
                session,
                "SENTINEL",
                "Case reopen refused: source device is not connected.",
            )
            print()
            print(tr("error.source_missing"))
            return

        update_status(
            session,
            status,
            session.source_device,
            assessment,
            intake=intake,
        )
        log_info(
            session,
            "SENTINEL",
            f"State routing decision: reopened to {status}",
        )

    if status in (
        RecoveryStatus.ON_HOLD,
        RecoveryStatus.AWAITING_CUSTOMER_RESPONSE,
    ):
        print()
        print(tr("route.label.case_status"), status)
        print(tr("route.status.paused"))
        resume_confirm = input(tr("route.prompt.resume")).strip().lower()

        if not _confirmed_yes(resume_confirm):
            log_operator(
                session,
                "SENTINEL",
                "Case resume declined.",
            )
            return

        log_operator(
            session,
            "SENTINEL",
            "Case resume approved.",
        )
        status = resolve_resume_status(session)
        session.status = status
        if session.source_device and assessment:
            update_status(
                session,
                status,
                session.source_device,
                assessment,
                intake=intake,
            )
        log_info(
            session,
            "SENTINEL",
            f"State routing decision: resumed to {status}",
        )

    print(tr("route.label.recovery_case"), session.session_id)
    print(tr("route.label.case_name"), session.case_name)
    print(tr("route.label.case_location"), session.recovery_path)
    print()

    if status == RecoveryStatus.NEW:
        if not intake.get("intake"):
            intake = collect_case_intake()
            log_info(
                session,
                "INTAKE",
                "Recovery case intake completed.",
            )

        log_info(
            session,
            "SENTINEL",
            "Assessment started.",
        )
        strategy, smart_result, workflow_results = (
            _run_assessment_pipeline(session, intake, devices)
        )
        _finish_session(
            session,
            assessment or session.assessment,
            strategy,
            smart_result,
            workflow_results,
            intake=intake,
        )
        return

    if status == RecoveryStatus.ASSESSING:
        assessment = _require_assessment(
            session,
            assessment,
            "Assessment workflow",
        )
        if assessment is None:
            return

        strategy, smart_result, workflow_results = (
            _run_assessment_pipeline(session, intake, devices)
        )
        _finish_session(
            session,
            assessment or session.assessment,
            strategy,
            smart_result,
            workflow_results,
            intake=intake,
        )
        return

    if status in (
        RecoveryStatus.READY_FOR_IMAGING,
        RecoveryStatus.IMAGING,
    ):
        if session.source_device is None:
            log_error(
                session,
                "SENTINEL",
                "Source device missing; cannot continue imaging workflow.",
            )
            print()
            print(tr("error.source_missing"))
            return

        assessment = _require_assessment(
            session,
            assessment,
            "Imaging workflow",
        )
        if assessment is None:
            return

        acquisition_state = classify_acquisition_state(session.recovery_path)

        if acquisition_state["state"] == "completed_canonical":
            log_warning(
                session,
                "SENTINEL",
                (
                    f"Stale persisted status {status}; canonical acquisition "
                    "is complete. Routing to READY_FOR_RECOVERY."
                ),
            )
            update_status(
                session,
                RecoveryStatus.READY_FOR_RECOVERY,
                session.source_device,
                assessment,
                intake=intake,
            )
            status = RecoveryStatus.READY_FOR_RECOVERY
        else:
            strategy = create_strategy(assessment)
            workflow_results = _run_acquisition_workflow(
                session,
                devices,
                assessment,
                intake,
            )
            _finish_session(
                session,
                assessment,
                strategy,
                smart_result,
                workflow_results,
                intake=intake,
            )
            return

    if status in (
        RecoveryStatus.READY_FOR_RECOVERY,
        RecoveryStatus.RECOVERING,
    ):
        if session.source_device is None:
            log_error(
                session,
                "SENTINEL",
                "Source device missing; cannot continue recovery workflow.",
            )
            print()
            print(tr("error.source_missing"))
            return

        assessment = _require_assessment(
            session,
            assessment,
            "Recovery workflow",
        )
        if assessment is None:
            return

        if status == RecoveryStatus.RECOVERING:
            log_info(
                session,
                "SENTINEL",
                "Interrupted recovery session; offering recovery operations.",
            )

        strategy = create_strategy(assessment)
        (
            workflow_results["recovery_result"],
            workflow_results["recovery_declined"],
            workflow_results["recovery_selection_cancelled"],
        ) = _run_recovery_method_selection(
            session,
            assessment,
            intake,
        )
        _finish_session(
            session,
            assessment,
            strategy,
            smart_result,
            workflow_results,
            intake=intake,
        )
        return

    log_error(
        session,
        "SENTINEL",
        f"No route available for status {status}.",
    )


def _print_startup_menu():
    print(tr("startup.menu.create"))
    print(tr("startup.menu.active"))
    print(tr("startup.menu.archived"))
    print(tr("startup.menu.language"))
    print(tr("startup.menu.cancel"))
    print()
    print(
        tr(
            "startup.language_line",
            language=_language_display_name(get_language()),
        )
    )
    print()


def _prompt_startup_menu():
    _print_startup_menu()

    while True:
        choice = input(tr("startup.prompt.select_action")).strip().lower()

        if choice == "1":
            return "new"
        if choice == "2":
            return "active"
        if choice == "3":
            return "archived"
        if choice in ("l", "language"):
            _prompt_language_selection()
            _print_startup_menu()
            continue
        if choice in ("c", "cancel"):
            return "cancel"

        print(tr("validation.invalid_selection"))


def _prompt_case_selection(records, *, title):
    print()
    print(title)
    print("=" * 42)
    print()

    for index, record in enumerate(records, start=1):
        print(f"[{index}] {record['session_id']}  {record['case_name']}")
        print(
            tr(
                "case.list.status",
                status=record["status"],
            )
        )
        print(
            tr(
                "case.list.created",
                created_at=record["created_at"],
            )
        )
        print(
            tr(
                "case.list.location",
                recovery_path=record["recovery_path"],
            )
        )
        for warning in record.get("warnings", []):
            print(tr("case.list.warning", warning=warning))
        print()

    print(tr("case.menu.cancel"))
    print()

    case_range = f"1-{len(records)}"

    while True:
        choice = input(
            tr("case.prompt.select_case", range=case_range)
        ).strip().lower()

        if choice in ("c", "cancel"):
            return None

        try:
            selection = int(choice)
        except ValueError:
            print(tr("validation.invalid_selection"))
            continue

        if 1 <= selection <= len(records):
            return records[selection - 1]

        print(tr("validation.invalid_selection"))


def _prompt_active_case_action(record):
    print()
    print(
        tr(
            "case.label.selected",
            session_id=record["session_id"],
            case_name=record["case_name"],
        )
    )
    print()
    print(tr("case.menu.open"))
    print(tr("case.menu.archive"))
    print(tr("case.menu.cancel"))
    print()

    while True:
        choice = input(tr("case.prompt.select_action")).strip().lower()

        if choice == "1":
            return "open"
        if choice == "2":
            return "archive"
        if choice in ("c", "cancel"):
            return "cancel"

        print(tr("validation.invalid_selection"))


def _open_selected_case(selected, devices):
    load_result = load_case(selected["recovery_path"], devices)

    for warning in load_result["warnings"]:
        print(tr("load.warning", warning=warning))

    if not load_result["success"]:
        print()
        print(operator_message(load_result, "load"))
        if load_result["session"] is not None:
            _log_case_load_failure(load_result["session"], load_result)
        return

    route_case(
        load_result["session"],
        load_result["intake"],
        load_result["assessment"],
        load_result["devices"],
        load_result["warnings"],
    )


def _open_archived_case(selected, devices):
    case_path = Path(selected["recovery_path"])
    permitted_roots = [
        root_info["path"]
        for root_info in enumerate_archive_roots(devices)
    ]

    try:
        manifest = read_case_manifest(
            case_path,
            permitted_roots=permitted_roots,
        )
    except ManifestError as error:
        print()
        print(error)
        return

    print()
    print(tr("case.label.recovery_case"), manifest["session_id"])
    print(tr("case.label.case_name"), manifest.get("case_name", ""))
    print(tr("case.label.status"), manifest["status"])
    print(tr("case.label.created"), manifest["created_at"])
    print(tr("case.label.location"), case_path)
    print()
    print(tr("case.archived.notice"))
    reopen_confirm = input(tr("case.reopen.confirm")).strip().lower()

    if not _confirmed_yes(reopen_confirm):
        return

    try:
        created_at = datetime.fromisoformat(manifest["created_at"])
    except ValueError:
        print()
        print(
            tr(
                "load.message.invalid_created_at",
                created_at=manifest["created_at"],
            )
        )
        return

    session = RecoverySession(
        session_id=manifest["session_id"],
        created_at=created_at,
        status=manifest["status"],
        recovery_path=str(case_path.resolve()),
        case_name=manifest.get("case_name", ""),
    )

    log_operator(
        session,
        "SENTINEL",
        "Archived case reopen approved.",
    )

    reopen_result = reopen_case(session)
    if not reopen_result["success"]:
        log_error(
            session,
            "SENTINEL",
            reopen_result["message"],
        )
        print()
        print(operator_message(reopen_result, "discovery"))
        return

    log_info(
        session,
        "SENTINEL",
        f"Case reopened: {reopen_result['message']}",
    )

    selected["recovery_path"] = session.recovery_path

    load_result = load_case(session.recovery_path, devices)

    for warning in load_result["warnings"]:
        print(tr("load.warning", warning=warning))

    if not load_result["success"]:
        print()
        print(operator_message(load_result, "load"))
        if load_result["session"] is not None:
            _log_case_load_failure(load_result["session"], load_result)
        return

    route_case(
        load_result["session"],
        load_result["intake"],
        load_result["assessment"],
        load_result["devices"],
        load_result["warnings"],
        archive_reopened=True,
    )


def _archive_selected_case(selected, devices):
    load_result = load_case(selected["recovery_path"], devices)

    for warning in load_result["warnings"]:
        print(tr("load.warning", warning=warning))

    session = load_result["session"]
    if session is None:
        print()
        print(operator_message(load_result, "load"))
        return

    print()
    print(tr("case.label.recovery_case"), session.session_id)
    print(tr("case.label.case_name"), session.case_name)
    print(tr("case.label.location"), session.recovery_path)
    print()

    archive_confirm = input(
        tr("case.archive.confirm", session_id=session.session_id)
    ).strip().lower()

    if not _confirmed_yes(archive_confirm):
        log_operator(
            session,
            "SENTINEL",
            "Case archive declined.",
        )
        print(tr("case.archive.cancelled"))
        return

    log_operator(
        session,
        "SENTINEL",
        "Case archive approved.",
    )

    archive_result = archive_case(session)
    if not archive_result["success"]:
        log_error(
            session,
            "SENTINEL",
            archive_result["message"],
        )
        print()
        print(operator_message(archive_result, "discovery"))
        return

    log_info(
        session,
        "SENTINEL",
        archive_result["message"],
    )
    print()
    print(operator_message(archive_result, "discovery"))


def _run_new_case():
    case_name = input(tr("case.name_prompt")).strip()

    session = create_session()
    intake = collect_case_intake()

    session.case_name = case_name

    if session.case_name == "":
        session.case_name = session.session_id

    write_initial_case_manifest(session)

    log_info(
        session,
        "SENTINEL",
        f"Case name set: {session.case_name}",
    )

    log_info(
        session,
        "INTAKE",
        "Recovery case intake completed.",
    )

    log_info(
        session,
        "SENTINEL",
        "Assessment started.",
    )

    devices = detect_devices()
    device_count = len(devices)

    if device_count == 1:
        log_info(
            session,
            "ARGUS",
            f"Detected 1 storage device: {devices[0].path}",
        )
    else:
        log_info(
            session,
            "ARGUS",
            f"Detected {device_count} storage devices.",
        )

    print(tr("case.label.recovery_case"), session.session_id)
    print(tr("case.label.case_name"), session.case_name)
    print()

    strategy, smart_result, workflow_results = _run_assessment_pipeline(
        session,
        intake,
        devices,
    )

    _finish_session(
        session,
        session.assessment,
        strategy,
        smart_result,
        workflow_results,
        intake=intake,
    )


def _run_active_cases():
    devices = detect_devices()
    discovery = discover_cases(devices, archived=False)

    for warning in discovery["warnings"]:
        print(tr("discovery.warning", warning=warning))

    if not discovery["records"]:
        print()
        print(tr("case.no_active"))
        return

    selected = _prompt_case_selection(
        discovery["records"],
        title=tr("case.active.title"),
    )
    if selected is None:
        print(tr("case.selection.cancelled"))
        return

    action = _prompt_active_case_action(selected)
    if action == "cancel":
        print(tr("case.action.cancelled"))
        return

    if action == "archive":
        _archive_selected_case(selected, devices)
        return

    _open_selected_case(selected, devices)


def _run_archived_cases():
    devices = detect_devices()
    discovery = discover_cases(devices, archived=True)

    for warning in discovery["warnings"]:
        print(tr("discovery.warning", warning=warning))

    if not discovery["records"]:
        print()
        print(tr("case.no_archived"))
        return

    selected = _prompt_case_selection(
        discovery["records"],
        title=tr("case.archived.title"),
    )
    if selected is None:
        print(tr("case.selection.cancelled"))
        return

    _open_archived_case(selected, devices)


def main():
    set_log_failure_handler(_handle_audit_log_failure)

    print("==========================================")
    print(tr("startup.title"))
    print("==========================================")
    print()

    action = _prompt_startup_menu()

    if action == "cancel":
        print(tr("startup.cancelled"))
        return

    if action == "new":
        _run_new_case()
        return

    if action == "active":
        _run_active_cases()
        return

    if action == "archived":
        _run_archived_cases()
        return


if __name__ == "__main__":
    main()
